# Copy this file to `.env` in travelhub_backend/ and fill in your values.
# Never commit `.env` to git.

# Database (shared Supabase — get credentials from team lead)
DB_URL=jdbc:postgresql://your-project.pooler.supabase.com:6543/postgres?prepareThreshold=0&sslmode=require
DB_USERNAME=postgres.your-project-ref
DB_PASSWORD=your-db-password

# App URLs (local dev)
APP_BASE_URL=http://localhost:5173
APP_BACKEND_URL=http://localhost:8080
ADMIN_EMAIL=your-admin@gmail.com

# Supabase storage (optional for image uploads)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Gmail SMTP (each developer uses their own app password)
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# JWT
JWT_SECRET=use-a-long-random-secret-at-least-32-characters

# PayHere sandbox (each developer uses their own sandbox merchant account)
PAYHERE_MERCHANT_ID=your-merchant-id
PAYHERE_MERCHANT_SECRET=your-merchant-secret
